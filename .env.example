# ============================================================
# ERP Purchase Order Management System — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# PostgreSQL
DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/erp_db

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# AI Service (optional — pick one)
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
AI_PROVIDER=gemini

# MongoDB (optional — for AI logging)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=erp_ai_logs

# App
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:8000
